package pages

import "{{.Name}}/app/views/layouts"

templ Home() {
	@layouts.Base("Home", "{{.Name}}", "", "") {
		<div class="mx-auto max-w-4xl px-4 py-16 sm:py-24 text-center">
			<h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">
				Welcome to
				<span class="text-indigo-600">{{.Name}}</span>
			</h1>
			<p class="mt-6 text-lg leading-8 text-gray-600 max-w-2xl mx-auto">
				Your application is up and running. Built with
				<a href="https://github.com/dayvsonlima/catuaba" class="text-indigo-600 hover:underline">Catuaba</a>,
				<a href="https://templ.guide" class="text-indigo-600 hover:underline">Templ</a>, and
				<a href="https://htmx.org" class="text-indigo-600 hover:underline">HTMX</a>.
			</p>
			<div class="mt-10 flex items-center justify-center gap-x-6">
				<a href="https://github.com/dayvsonlima/catuaba" class="rounded-md bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
					Documentation
				</a>
				<a href="https://github.com/dayvsonlima/catuaba" class="text-sm font-semibold text-gray-900 hover:text-indigo-600">
					View on GitHub →
				</a>
			</div>
			<div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-3">
				<div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
					<h3 class="text-lg font-semibold text-gray-900">Server-Side Rendered</h3>
					<p class="mt-2 text-sm text-gray-600">Type-safe HTML with Templ. No JavaScript framework needed.</p>
				</div>
				<div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
					<h3 class="text-lg font-semibold text-gray-900">Interactive with HTMX</h3>
					<p class="mt-2 text-sm text-gray-600">Rich interactivity via HTML attributes. Zero custom JS required.</p>
				</div>
				<div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
					<h3 class="text-lg font-semibold text-gray-900">Styled with Tailwind</h3>
					<p class="mt-2 text-sm text-gray-600">Utility-first CSS. Production-ready and responsive out of the box.</p>
				</div>
			</div>
		</div>
	}
}
