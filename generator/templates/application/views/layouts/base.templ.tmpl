package layouts

import (
	"os"
	"{{.Name}}/app/views/components"
)

templ Base(title string, flashMsg string, flashType string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title } — { os.Getenv("APP_NAME") }</title>
			<link rel="icon" href="data:,"/>
			<link rel="stylesheet" href="/static/css/app.css"/>
			<script src="https://unpkg.com/htmx.org@2.0.4" integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+" crossorigin="anonymous"></script>
			<script defer src="https://unpkg.com/alpinejs@3.14.8/dist/cdn.min.js"></script>
			<script>
				(function() {
					function getCSRFToken() {
						var match = document.cookie.match(/(?:^| )_csrf_token=([^;]+)/);
						return match ? match[1] : '';
					}
					function injectCSRFInput(form) {
						if (form.method && form.method.toUpperCase() === 'POST' && !form.querySelector('input[name="_csrf_token"]')) {
							var input = document.createElement('input');
							input.type = 'hidden';
							input.name = '_csrf_token';
							input.value = getCSRFToken();
							form.prepend(input);
						}
					}
					function injectAll(root) {
						(root || document).querySelectorAll('form[method="POST"],form[method="post"]').forEach(injectCSRFInput);
					}
					document.addEventListener('htmx:configRequest', function(event) {
						var token = getCSRFToken();
						if (token) event.detail.headers['X-CSRF-Token'] = token;
					});
					document.addEventListener('DOMContentLoaded', function() { injectAll(); });
					document.addEventListener('htmx:afterSwap', function(event) { injectAll(event.detail.elt); });
				})();
			</script>
		</head>
		<body class="min-h-screen bg-gray-50 text-gray-900 flex flex-col" hx-boost="true" hx-indicator="#htmx-progress">
			<div id="htmx-progress" class="htmx-indicator fixed top-0 left-0 z-[100] h-0.5 w-full">
				<div class="h-full animate-progress bg-primary-600"></div>
			</div>
			@components.Nav()
			if flashMsg != "" {
				@components.Flash(flashMsg, flashType)
			}
			<main class="flex-1">
				{ children... }
			</main>
			<footer class="border-t border-gray-200 py-6 text-center text-sm text-gray-500">
				<p>Built with <a href="https://github.com/dayvsonlima/catuaba" class="text-primary-600 transition-colors duration-150 hover:text-primary-800 hover:underline">Catuaba</a></p>
			</footer>
		</body>
	</html>
}
