package components

templ FormField(name string, label string, inputType string, value string, errMsg string) {
	<div class="mb-4">
		<label for={ name } class="block text-sm font-medium text-gray-700 mb-1">
			{ label }
		</label>
		<input
			type={ inputType }
			id={ name }
			name={ name }
			value={ value }
			class={ "block w-full rounded-md border px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500",
				templ.KV("border-red-300 focus:border-red-500", errMsg != ""),
				templ.KV("border-gray-300 focus:border-indigo-500", errMsg == "") }
		/>
		if errMsg != "" {
			<p class="mt-1 text-sm text-red-600">{ errMsg }</p>
		}
	</div>
}

templ TextAreaField(name string, label string, value string, errMsg string) {
	<div class="mb-4">
		<label for={ name } class="block text-sm font-medium text-gray-700 mb-1">
			{ label }
		</label>
		<textarea
			id={ name }
			name={ name }
			rows="4"
			class={ "block w-full rounded-md border px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500",
				templ.KV("border-red-300 focus:border-red-500", errMsg != ""),
				templ.KV("border-gray-300 focus:border-indigo-500", errMsg == "") }
		>
			{ value }
		</textarea>
		if errMsg != "" {
			<p class="mt-1 text-sm text-red-600">{ errMsg }</p>
		}
	</div>
}
