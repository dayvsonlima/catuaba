package components

type SelectOption struct {
	Value string
	Label string
}

templ FormField(name string, label string, inputType string, value string, errMsg string) {
	<div class="mb-4">
		<label for={ name } class="block text-sm font-medium text-gray-700 mb-1">
			{ label }
		</label>
		<input
			type={ inputType }
			id={ name }
			name={ name }
			value={ value }
			if errMsg != "" {
				aria-describedby={ name + "-error" }
				aria-invalid="true"
			}
			class={ "block w-full rounded-md border px-3 py-2 text-sm shadow-sm transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-primary-500",
				templ.KV("border-red-300 focus:border-red-500", errMsg != ""),
				templ.KV("border-gray-300 focus:border-primary-500", errMsg == "") }
		/>
		if errMsg != "" {
			<p id={ name + "-error" } class="mt-1 text-sm text-red-600">{ errMsg }</p>
		}
	</div>
}

templ CheckboxField(name string, label string, checked bool, errMsg string) {
	<div class="mb-4">
		<div class="flex items-center gap-2">
			<input
				type="checkbox"
				id={ name }
				name={ name }
				value="true"
				checked?={ checked }
				if errMsg != "" {
					aria-describedby={ name + "-error" }
					aria-invalid="true"
				}
				class="h-4 w-4 rounded border-gray-300 text-primary-600 transition-colors duration-150 focus:ring-primary-500"
			/>
			<label for={ name } class="text-sm font-medium text-gray-700">
				{ label }
			</label>
		</div>
		if errMsg != "" {
			<p id={ name + "-error" } class="mt-1 text-sm text-red-600">{ errMsg }</p>
		}
	</div>
}

templ TextAreaField(name string, label string, value string, errMsg string) {
	<div class="mb-4">
		<label for={ name } class="block text-sm font-medium text-gray-700 mb-1">
			{ label }
		</label>
		<textarea
			id={ name }
			name={ name }
			rows="4"
			if errMsg != "" {
				aria-describedby={ name + "-error" }
				aria-invalid="true"
			}
			class={ "block w-full rounded-md border px-3 py-2 text-sm shadow-sm transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-primary-500",
				templ.KV("border-red-300 focus:border-red-500", errMsg != ""),
				templ.KV("border-gray-300 focus:border-primary-500", errMsg == "") }
		>
			{ value }
		</textarea>
		if errMsg != "" {
			<p id={ name + "-error" } class="mt-1 text-sm text-red-600">{ errMsg }</p>
		}
	</div>
}

templ SelectField(name string, label string, options []SelectOption, selected string, errMsg string) {
	<div class="mb-4">
		<label for={ name } class="block text-sm font-medium text-gray-700 mb-1">
			{ label }
		</label>
		<select
			id={ name }
			name={ name }
			if errMsg != "" {
				aria-describedby={ name + "-error" }
				aria-invalid="true"
			}
			class={ "block w-full rounded-md border px-3 py-2 text-sm shadow-sm transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-primary-500",
				templ.KV("border-red-300 focus:border-red-500", errMsg != ""),
				templ.KV("border-gray-300 focus:border-primary-500", errMsg == "") }
		>
			for _, opt := range options {
				<option value={ opt.Value } selected?={ opt.Value == selected }>{ opt.Label }</option>
			}
		</select>
		if errMsg != "" {
			<p id={ name + "-error" } class="mt-1 text-sm text-red-600">{ errMsg }</p>
		}
	</div>
}
