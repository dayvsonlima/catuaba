package components

templ PrimaryButton(text string) {
	<button type="submit" class="inline-flex items-center justify-center rounded-md bg-primary-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors duration-150 hover:bg-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2">
		{ text }
	</button>
}

templ PrimaryLinkButton(href string, text string) {
	<a href={ templ.SafeURL(href) } class="inline-flex items-center justify-center rounded-md bg-primary-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors duration-150 hover:bg-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2">
		{ text }
	</a>
}

templ OutlineButton(text string) {
	<button type="submit" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm transition-colors duration-150 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2">
		{ text }
	</button>
}

templ DangerButton(text string) {
	<button type="submit" class="inline-flex items-center justify-center rounded-md bg-red-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm transition-colors duration-150 hover:bg-red-500 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">
		{ text }
	</button>
}

templ LinkButton(href string, text string) {
	<a href={ templ.SafeURL(href) } class="text-sm text-gray-600 transition-colors duration-150 hover:text-gray-900">
		{ text }
	</a>
}
