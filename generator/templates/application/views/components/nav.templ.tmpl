package components

import "os"
{{if .Auth}}
import "{{.Name}}/middleware"
{{end}}
templ Nav() {
	<nav class="bg-white border-b border-gray-200 px-4 sm:px-6 lg:px-8" x-data="{ open: false }">
		<div class="mx-auto max-w-7xl flex h-16 items-center justify-between">
			<a href="/" class="text-xl font-bold text-primary-600">{ os.Getenv("APP_NAME") }</a>
			<!-- Desktop nav -->
			<div class="hidden sm:flex sm:items-center sm:gap-4">
				<a href="/" class="text-sm text-gray-600 transition-colors duration-150 hover:text-gray-900">Home</a>
{{if .Auth}}				if middleware.SessionManager.GetString(ctx, "userName") != "" {
					<span class="text-sm text-gray-700">{ middleware.SessionManager.GetString(ctx, "userName") }</span>
					<form method="POST" action="/logout" class="inline">
						<button type="submit" class="text-sm text-gray-600 transition-colors duration-150 hover:text-gray-900">Sign out</button>
					</form>
				} else {
					<a href="/login" class="text-sm text-gray-600 transition-colors duration-150 hover:text-gray-900">Sign in</a>
					<a href="/register" class="rounded-md bg-primary-600 px-3 py-1.5 text-sm font-medium text-white transition-colors duration-150 hover:bg-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2">Sign up</a>
				}
{{end}}			</div>
			<!-- Mobile hamburger -->
			<button @click="open = !open" class="sm:hidden rounded-md p-2 text-gray-600 transition-colors duration-150 hover:bg-gray-100 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-500" aria-label="Toggle menu">
				<svg x-show="!open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
				</svg>
				<svg x-show="open" x-cloak class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
				</svg>
			</button>
		</div>
		<!-- Mobile menu -->
		<div x-show="open" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-1" x-transition:enter-end="opacity-100 translate-y-0" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 translate-y-0" x-transition:leave-end="opacity-0 -translate-y-1" class="sm:hidden border-t border-gray-200 py-3 space-y-1">
			<a href="/" class="block rounded-md px-3 py-2 text-sm text-gray-600 transition-colors duration-150 hover:bg-gray-100 hover:text-gray-900">Home</a>
{{if .Auth}}			if middleware.SessionManager.GetString(ctx, "userName") != "" {
				<span class="block px-3 py-2 text-sm text-gray-700">{ middleware.SessionManager.GetString(ctx, "userName") }</span>
				<form method="POST" action="/logout">
					<button type="submit" class="block w-full text-left rounded-md px-3 py-2 text-sm text-gray-600 transition-colors duration-150 hover:bg-gray-100 hover:text-gray-900">Sign out</button>
				</form>
			} else {
				<a href="/login" class="block rounded-md px-3 py-2 text-sm text-gray-600 transition-colors duration-150 hover:bg-gray-100 hover:text-gray-900">Sign in</a>
				<a href="/register" class="block rounded-md px-3 py-2 text-sm font-medium text-primary-600 transition-colors duration-150 hover:bg-primary-50">Sign up</a>
			}
{{end}}		</div>
	</nav>
}
