.PHONY: dev dev-stop build test lint clean docker-up docker-down tidy help setup

APP_NAME={{.Name}}
GOBIN=$(shell go env GOPATH)/bin
PID_DIR=tmp/pids

## dev: Start development with hot reload (templ + tailwind + go)
dev: dev-stop
	@mkdir -p $(PID_DIR)
	@command -v templ >/dev/null 2>&1 || { echo "Installing templ..."; go install github.com/a-h/templ/cmd/templ@latest; }
	@test -d node_modules || npm install
	@npx @tailwindcss/cli -i static/css/input.css -o static/css/app.css
	@PATH="$(GOBIN):$$PATH" templ generate -watch -proxy="http://localhost:8080" -cmd="go run ." & echo $$! > $(PID_DIR)/templ.pid
	@npx @tailwindcss/cli -i static/css/input.css -o static/css/app.css --watch

## dev-stop: Stop running dev processes
dev-stop:
	@if [ -d $(PID_DIR) ]; then \
		for f in $(PID_DIR)/*.pid; do \
			if [ -f "$$f" ]; then \
				pid=$$(cat "$$f"); \
				kill -TERM -$$pid 2>/dev/null || kill -TERM $$pid 2>/dev/null; \
				rm -f "$$f"; \
			fi; \
		done; \
	fi
	@lsof -ti :8080 -ti :7331 2>/dev/null | xargs kill -9 2>/dev/null || true

## setup: Install development dependencies
setup:
	go install github.com/a-h/templ/cmd/templ@latest
	npm install

## build: Build the application binary
build:
	@test -d node_modules || npm install
	@PATH="$(GOBIN):$$PATH" templ generate
	@npx @tailwindcss/cli -i static/css/input.css -o static/css/app.css --minify
	@go build -ldflags="-w -s" -o ./bin/$(APP_NAME) .

## test: Run all tests
test:
	@go test ./... -v

## lint: Run linter (requires golangci-lint)
lint:
	@golangci-lint run ./...

## clean: Remove build artifacts
clean:
	@rm -rf ./bin ./tmp

## docker-up: Start all services with Docker Compose
docker-up:
	@docker compose up -d --build

## docker-down: Stop all Docker Compose services
docker-down:
	@docker compose down

## tidy: Run go mod tidy
tidy:
	@go mod tidy

## help: Show this help
help:
	@echo "Available targets:"
	@grep -E '^## ' Makefile | sed 's/## /  /'
