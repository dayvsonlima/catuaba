package middleware

import (
	"net/url"

	"github.com/gin-gonic/gin"
)

const (
	flashMsgKey  = "_flash_msg"
	flashTypeKey = "_flash_type"
)

// SetFlash stores a flash message in the cookie for the next request.
func SetFlash(ctx *gin.Context, flashType string, message string) {
	ctx.SetCookie(flashMsgKey, url.QueryEscape(message), 5, "/", "", false, true)
	ctx.SetCookie(flashTypeKey, url.QueryEscape(flashType), 5, "/", "", false, true)
}

// GetFlash reads and clears the flash message from cookies.
func GetFlash(ctx *gin.Context) (string, string) {
	rawMsg, err := ctx.Cookie(flashMsgKey)
	if err != nil || rawMsg == "" {
		return "", ""
	}

	msg, _ := url.QueryUnescape(rawMsg)
	if msg == "" {
		return "", ""
	}

	rawType, _ := ctx.Cookie(flashTypeKey)
	flashType, _ := url.QueryUnescape(rawType)
	if flashType == "" {
		flashType = "success"
	}

	// Clear the cookies
	ctx.SetCookie(flashMsgKey, "", -1, "/", "", false, true)
	ctx.SetCookie(flashTypeKey, "", -1, "/", "", false, true)

	return msg, flashType
}
