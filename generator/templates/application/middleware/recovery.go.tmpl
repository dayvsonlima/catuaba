package middleware

import (
	"log/slog"
	"net/http"
	"runtime/debug"
	"strings"

	"github.com/gin-gonic/gin"
)

// Recovery returns a middleware that recovers from panics and logs them
func Recovery() gin.HandlerFunc {
	return func(ctx *gin.Context) {
		defer func() {
			if err := recover(); err != nil {
				slog.Error("Panic recovered",
					slog.Any("error", err),
					slog.String("path", ctx.Request.URL.Path),
					slog.String("method", ctx.Request.Method),
					slog.String("stack", string(debug.Stack())),
				)

				if strings.HasPrefix(ctx.Request.URL.Path, "/api/") {
					ctx.AbortWithStatusJSON(http.StatusInternalServerError, gin.H{
						"error": "Internal server error",
					})
				} else {
					ctx.Writer.Header().Set("Content-Type", "text/html; charset=utf-8")
					ctx.Writer.WriteHeader(http.StatusInternalServerError)
					ctx.Writer.WriteString(errorPageHTML)
					ctx.Abort()
				}
			}
		}()

		ctx.Next()
	}
}

const errorPageHTML = `<!doctype html>
<html lang="en">
<head>
	<meta charset="UTF-8"/>
	<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
	<title>Server Error</title>
	<style>
		body{font-family:system-ui,sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;background:#f9fafb;color:#111827}
		.c{text-align:center}
		.code{font-size:3.75rem;font-weight:700;color:#dc2626}
		h1{margin-top:1rem;font-size:1.875rem;font-weight:700}
		p{margin-top:.5rem;color:#6b7280}
		a{display:inline-block;margin-top:1.5rem;padding:.5rem 1rem;background:#4f46e5;color:#fff;border-radius:.375rem;text-decoration:none;font-size:.875rem;font-weight:600}
		a:hover{background:#4338ca}
	</style>
</head>
<body>
	<div class="c">
		<p class="code">500</p>
		<h1>Something went wrong</h1>
		<p>An unexpected error occurred. Please try again later.</p>
		<a href="/">Go home</a>
	</div>
</body>
</html>`
