package {{.Name|toPlural|toSnake}}_test

import (
	"encoding/json"
	"net/http"
	"net/http/httptest"
	"testing"

	"github.com/gin-gonic/gin"
	"github.com/stretchr/testify/assert"

	"{{moduleName}}/app/controllers/{{.Name|toPlural|toSnake}}"
)

func TestDelete(t *testing.T) {
	gin.SetMode(gin.TestMode)

	t.Run("returns 404 when record not found", func(t *testing.T) {
		router := gin.New()
		router.DELETE("/{{.Name|toPlural|toSnake}}/:id", {{.Name|toPlural|toSnake}}.Delete)

		w := httptest.NewRecorder()
		req, _ := http.NewRequest("DELETE", "/{{.Name|toPlural|toSnake}}/999999", nil)
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusNotFound, w.Code)

		var response map[string]interface{}
		json.Unmarshal(w.Body.Bytes(), &response)
		assert.Contains(t, response, "error")
	})
}
