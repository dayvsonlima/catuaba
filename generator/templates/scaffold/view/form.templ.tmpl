package {{.Name|toPlural|toSnake}}

import (
	"fmt"
	"{{moduleName}}/app/models"
	"{{moduleName}}/app/views/layouts"
)

templ Form(item models.{{.Name|toModelName}}, isEdit bool, errors map[string]string, flashMsg string, flashType string) {
	@layouts.Base(formTitle(isEdit), "", flashMsg, flashType) {
		<div class="mx-auto max-w-2xl px-4 py-8 sm:px-6 lg:px-8">
			<div class="mb-6">
				<a href="/{{.Name|toPlural|toSnake}}" class="text-sm text-indigo-600 hover:underline">← Back to {{.Name|toPlural}}</a>
			</div>
			<div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
				<h1 class="text-xl font-bold text-gray-900 mb-6">{ formTitle(isEdit) }</h1>
				if errors != nil {
					if msg, ok := errors["base"]; ok {
						<div class="mb-4 rounded-md bg-red-50 border border-red-200 p-4">
							<p class="text-sm text-red-800">{ msg }</p>
						</div>
					}
				}
				<form method="POST" action={ formAction(item, isEdit) }>
					{{ range .Params}}<div class="mb-4">
						<label for="{{. | toAttrName | toSnake}}" class="block text-sm font-medium text-gray-700 mb-1">{{. | toFormLabel}}</label>
						{{ if eq (. | toFormInput) "checkbox" }}<input type="hidden" name="{{. | toAttrName | toSnake}}" value="false"/>
						<input type="checkbox" id="{{. | toAttrName | toSnake}}" name="{{. | toAttrName | toSnake}}" value="true" checked?={ item.{{. | toAttrName}} } class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500"/>
						{{ else if eq (. | toFormInput) "textarea" }}<textarea id="{{. | toAttrName | toSnake}}" name="{{. | toAttrName | toSnake}}" rows="6" class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500">{ fmt.Sprintf("%v", item.{{. | toAttrName}}) }</textarea>
						{{ else }}<input type="{{. | toFormInput}}" id="{{. | toAttrName | toSnake}}" name="{{. | toAttrName | toSnake}}" value={ fmt.Sprintf("%v", item.{{. | toAttrName}}) } class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"/>
						{{ end }}
					</div>
					{{ end }}<div class="flex items-center gap-4 pt-4">
						<button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500">
							if isEdit {
								Update {{.Name}}
							} else {
								Create {{.Name}}
							}
						</button>
						<a href="/{{.Name|toPlural|toSnake}}" class="text-sm text-gray-600 hover:text-gray-900">Cancel</a>
					</div>
				</form>
			</div>
		</div>
	}
}

func formTitle(isEdit bool) string {
	if isEdit {
		return "Edit {{.Name}}"
	}
	return "New {{.Name}}"
}

func formAction(item models.{{.Name|toModelName}}, isEdit bool) templ.SafeURL {
	if isEdit {
		return templ.SafeURL(fmt.Sprintf("/{{.Name|toPlural|toSnake}}/%d", item.ID))
	}
	return "/{{.Name|toPlural|toSnake}}"
}
