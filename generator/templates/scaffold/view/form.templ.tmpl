package {{.Name|toPlural|toSnake}}

import (
	"fmt"
	"{{moduleName}}/app/models"
	"{{moduleName}}/app/views/layouts"
	"{{moduleName}}/app/views/components"
)

templ Form(item models.{{.Name|toModelName}}, isEdit bool, errors map[string]string, flashMsg string, flashType string) {
	@layouts.Base(formTitle(isEdit), flashMsg, flashType) {
		<div class="mx-auto max-w-2xl px-4 py-8 sm:px-6 lg:px-8">
			@components.BackLink("/{{.Name|toPlural|toSnake}}", "Back to {{.Name|toPlural}}")
			@components.Card() {
				@components.CardBody() {
					<h1 class="text-xl font-bold text-gray-900 mb-6">{ formTitle(isEdit) }</h1>
					if errors != nil {
						if msg, ok := errors["base"]; ok {
							<div class="mb-4 rounded-md bg-red-50 border border-red-200 p-4">
								<p class="text-sm text-red-800">{ msg }</p>
							</div>
						}
					}
					<form method="POST" action={ formAction(item, isEdit) }>
						{{ range .Params}}{{ if eq (. | toFormInput) "checkbox" }}@components.CheckboxField("{{. | toAttrName | toSnake}}", "{{. | toFormLabel}}", item.{{. | toAttrName}}, errors["{{. | toAttrName | toSnake}}"])
						{{ else if eq (. | toFormInput) "textarea" }}@components.TextAreaField("{{. | toAttrName | toSnake}}", "{{. | toFormLabel}}", formatField(item.{{. | toAttrName}}, isEdit), errors["{{. | toAttrName | toSnake}}"])
						{{ else }}@components.FormField("{{. | toAttrName | toSnake}}", "{{. | toFormLabel}}", "{{. | toFormInput}}", formatField(item.{{. | toAttrName}}, isEdit), errors["{{. | toAttrName | toSnake}}"])
						{{ end }}{{ end }}@components.FormActions() {
							@components.PrimaryButton(formButtonText(isEdit))
							@components.LinkButton("/{{.Name|toPlural|toSnake}}", "Cancel")
						}
					</form>
				}
			}
		</div>
	}
}

func formTitle(isEdit bool) string {
	if isEdit {
		return "Edit {{.Name}}"
	}
	return "New {{.Name}}"
}

func formButtonText(isEdit bool) string {
	if isEdit {
		return "Update {{.Name}}"
	}
	return "Create {{.Name}}"
}

func formatField(value any, isEdit bool) string {
	s := fmt.Sprintf("%v", value)
	if !isEdit && (s == "0" || s == "") {
		return ""
	}
	return s
}

func formAction(item models.{{.Name|toModelName}}, isEdit bool) templ.SafeURL {
	if isEdit {
		return templ.SafeURL(fmt.Sprintf("/{{.Name|toPlural|toSnake}}/%d", item.ID))
	}
	return "/{{.Name|toPlural|toSnake}}"
}
