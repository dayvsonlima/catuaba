package {{.Name|toPlural|toSnake}}

import (
	"fmt"
	"{{moduleName}}/app/models"
	"{{moduleName}}/app/views/layouts"
	"{{moduleName}}/app/views/components"
)

templ Index(items []models.{{.Name|toModelName}}, page int, totalPages int, flashMsg string, flashType string) {
	@layouts.Base("{{.Name|toPlural}}", flashMsg, flashType) {
		<div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8" id="content">
			@components.PageHeader("{{.Name|toPlural}}") {
				@components.PrimaryLinkButton("/{{.Name|toPlural|toSnake}}/new", "New {{.Name}}")
			}
			if len(items) == 0 {
				@components.EmptyState("No {{.Name|toPlural|toSnake}} found.", "/{{.Name|toPlural|toSnake}}/new", "Create the first one")
			} else {
				@components.Table() {
					<thead class="bg-gray-50">
						<tr>
							<th scope="col" class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">ID</th>
							{{ range .Params}}<th scope="col" class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">{{. | toFormLabel}}</th>
							{{ end }}<th scope="col" class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-500">Actions</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-gray-200 bg-white">
						for _, item := range items {
							<tr class="transition-colors duration-150 hover:bg-gray-50">
								<td class="whitespace-nowrap px-4 py-3 text-sm text-gray-900">{ fmt.Sprintf("%d", item.ID) }</td>
								{{ range .Params}}{{ if eq (. | toFormInput) "textarea" }}<td class="px-4 py-3 text-sm text-gray-600 max-w-xs truncate" title={ fmt.Sprintf("%v", item.{{. | toAttrName}}) }>{ fmt.Sprintf("%v", item.{{. | toAttrName}}) }</td>
								{{ else if eq (. | toFormInput) "checkbox" }}<td class="whitespace-nowrap px-4 py-3 text-sm text-gray-600">
									@components.BooleanBadge(item.{{. | toAttrName}})
								</td>
								{{ else }}<td class="whitespace-nowrap px-4 py-3 text-sm text-gray-600">{ fmt.Sprintf("%v", item.{{. | toAttrName}}) }</td>
								{{ end }}{{ end }}<td class="whitespace-nowrap px-4 py-3 text-right text-sm">
									<div class="inline-flex items-center gap-1">
										<a href={ templ.SafeURL(fmt.Sprintf("/{{$.Name|toPlural|toSnake}}/%d", item.ID)) } class="inline-flex items-center gap-1 rounded px-2 py-1 text-primary-600 transition-colors duration-150 hover:bg-primary-50 hover:text-primary-800" title="View">
											<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path></svg>
											<span class="hidden sm:inline">View</span>
										</a>
										<a href={ templ.SafeURL(fmt.Sprintf("/{{$.Name|toPlural|toSnake}}/%d/edit", item.ID)) } class="inline-flex items-center gap-1 rounded px-2 py-1 text-primary-600 transition-colors duration-150 hover:bg-primary-50 hover:text-primary-800" title="Edit">
											<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"></path></svg>
											<span class="hidden sm:inline">Edit</span>
										</a>
									</div>
								</td>
							</tr>
						}
					</tbody>
				}
				@components.Pagination(page, totalPages, "/{{.Name|toPlural|toSnake}}")
			}
		</div>
	}
}
